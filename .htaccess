DirectorySlash Off
RewriteEngine On

# Handle /blog specifically - serve blog.html (because blog/ folder exists)
RewriteRule ^blog/?$ blog.html [L]

# Remove .html extension from URLs (redirect)
RewriteCond %{THE_REQUEST} /([^.]+)\.html [NC]
RewriteRule ^ /%1 [NC,L,R=301]

# Serve .html file for extensionless URLs
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]
